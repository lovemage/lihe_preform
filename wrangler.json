{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lihepreform02",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-08",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "CONTENT_DB",
      "database_name": "lihe_db",
      "database_id": "fea9f23b-c953-4b9a-bc6c-dfb200c25da5"
    }
  ],
  "r2_buckets": [
    {
      "binding": "CONTENT_MEDIA",
      "bucket_name": "lihe-preform-media"
    }
  ]
}
